# Copy this file to .env and configure your preferred LLM backend.

# ── LLM Backend ──────────────────────────────────────────────────────────────
# "azure"     → Azure OpenAI Service (for Azure VM deployments)
# "local"     → Ollama (runs on your machine, no data leaves the computer)
# "anthropic" → Claude via Anthropic API
# "gemini"    → Gemini via Google AI Gemini API (API key)
# "vertex"    → Gemini/Claude via Google Vertex AI (uses Application Default Credentials)
LLM_BACKEND=azure

# ── Azure OpenAI settings (used when LLM_BACKEND=azure) ──────────────────────
# Requires: pip install openai  (already in requirements.txt)
# Setup:
#   1. Create an Azure OpenAI resource in the Azure portal
#   2. Deploy a model (e.g. gpt-4o) under that resource
#   3. Copy the endpoint and key from the "Keys and Endpoint" blade
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Local Ollama settings (used when LLM_BACKEND=local) ──────────────────────
# Install Ollama: https://ollama.com
# Then pull the model:  ollama pull gemma3:12b
LOCAL_LLM_MODEL=gemma3:12b
LOCAL_LLM_URL=http://localhost:11434/v1

# ── Anthropic / Claude settings (used when LLM_BACKEND=anthropic) ────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Gemini API settings (used when LLM_BACKEND=gemini) ───────────────────────
# Requires: pip install google-genai
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-pro

# ── Vertex AI / Gemini settings (used when LLM_BACKEND=vertex) ───────────────
# Requires: pip install google-cloud-aiplatform
# Auth:     gcloud auth application-default login
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-pro
